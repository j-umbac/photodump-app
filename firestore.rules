rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // User settings — only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow public read of specific fields needed by the upload page
      // (the upload page needs gdriveConnected, gdriveAccessToken, gdriveFolderId)
      allow read: if true;
    }

    // Dump documents — anyone can read (public upload pages), only creator can write
    match /dumps/{dumpId} {
      allow read: if true;
      allow write: if request.auth != null && (
        !resource.data.keys().hasAny(['creatorId']) || 
        resource.data.creatorId == request.auth.uid ||
        request.resource.data.creatorId == request.auth.uid
      );

      // Files subcollection — anyone can create (public uploaders), only creator can delete
      match /files/{fileId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null;
      }
    }
  }
}
